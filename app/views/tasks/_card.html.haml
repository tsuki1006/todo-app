.task_card
  = form_with(model: task, url: task_completion_path(task, type: type), method: 'put', local: true, data: { controller: 'task' }) do |f|
    = f.check_box :completed, data: { action: 'change->task#completionSubmit' }, class: 'form-check-input'

  = link_to edit_task_path(task, type: type), data: { turbo_frame: 'task-modal' }, class: 'task_content' do
    %div= task.title
    %div.task_content_deadline{ class: "#{add_alert_class(task)}" }= task.display_deadline
