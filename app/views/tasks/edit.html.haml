= turbo_frame_tag 'task-modal' do
  .modal.bg-dark.bg-opacity-50{ data: { controller: 'modal', modal_target: 'backGround', action: "click->modal#closeBackground" } }
    .modal-dialog.modal-dialog-centered.modal-xl

      .modal-content
        .modal-header
          %button.btn-close{ type: 'button', data: { action: 'click->modal#closeModal' } }

        .modal-body
          = render 'task_detail', task: @task, type: @type

          = link_to task_path(@task, type: @type), data: { turbo_frame: '_top', turbo_method: :delete, turbo_confirm: 'タスクを削除しますか？' }, class: 'task_delete' do
            %i.fa-regular.fa-trash-can.modal_delete_icon{:style => "color: rgb(161, 161, 161);"}
